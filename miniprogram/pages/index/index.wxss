.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* ── 分类 Tab ── */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 0 var(--space-sm);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  position: sticky;
  top: 0;
  z-index: 10;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: var(--space-md) 0;
  font-size: var(--font-md);
  color: var(--color-text-secondary);
  position: relative;
}
.tab-active {
  color: var(--color-primary);
  font-weight: 600;
}
.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: var(--color-primary);
  border-radius: 3rpx;
}

/* ── 控制栏 (搜索 + 排序) ── */
.control-bar {
  background: #fff;
  padding: var(--space-sm) var(--space-md);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
  z-index: 9;
}

/* 搜索容器 */
.search-container {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-md);
}

/* 搜索框 */
.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f6f8;
  border-radius: 36rpx;
  height: 72rpx;
  padding: 0 24rpx;
}
.search-icon {
  font-size: 32rpx;
  color: #A0A5AF;
  margin-right: 12rpx;
}
.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

/* 搜索文字按钮 */
.search-action {
  font-size: 30rpx;
  color: var(--color-primary);
  font-weight: 600;
  margin-left: 24rpx;
  padding: 10rpx 0;
  white-space: nowrap;
}

/* 排序栏 */
.sort-bar {
  display: flex;
  gap: var(--space-md);
}
.sort-item {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  background: var(--color-bg-page);
  transition: all 0.2s;
}
.sort-active {
  color: var(--color-primary);
  background: rgba(103, 194, 58, 0.1);
  font-weight: 600;
}

/* ── 瀑布流列表 ── */
.waterfall-scroll {
  flex: 1;
  background: var(--color-bg-page);
}

.waterfall-container {
  padding: var(--space-sm);
  column-count: 2;
  column-gap: var(--space-sm);
}

/* ── 瀑布流卡片 ── */
.waterfall-card {
  break-inside: avoid;
  margin-bottom: var(--space-sm);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.waterfall-card:active { transform: scale(0.98); transition: transform 0.15s;}

/* 封面 */
.card-cover {
  width: 100%;
  max-height: 480rpx; /* Prevent overly tall images */
  display: block;
}

/* 内容区 */
.card-content {
  padding: 16rpx;
}

.card-header {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.card-meta {
  margin-bottom: 12rpx;
}
.reward {
  font-size: 32rpx;
  color: #FF5000;
  font-weight: 700;
}
.reward.no-reward {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.publisher-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.publisher-avatar {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #eee;
}
.publisher-name {
  font-size: 20rpx;
  color: #999;
}

/* ── 空状态、加载更多 ── */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}
.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* ── 加载更多动画 ── */
.load-more {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  padding: var(--space-lg) 0;
}
.loading-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-primary);
  animation: bounce 1.2s infinite ease-in-out;
}
.loading-dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce {
  0%,80%,100% { transform: scale(0.4); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}
.no-more {
  text-align: center;
  font-size: var(--font-xs);
  color: var(--color-text-placeholder);
  padding: var(--space-md) 0;
}
