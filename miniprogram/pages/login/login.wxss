.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #67C23A 0%, #4E9B2A 60%, #3a7d1e 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  overflow: hidden;
}

/* ── 装饰圆 ── */
.deco-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
}
.deco-1 { width: 500rpx; height: 500rpx; top: -160rpx; right: -160rpx; }
.deco-2 { width: 300rpx; height: 300rpx; bottom: 200rpx; left: -100rpx; }

/* ── Hero 区域 ── */
.hero {
  margin-top: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.logo-ring {
  width: 160rpx; height: 160rpx; border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 32rpx;
  border: 4rpx solid rgba(255,255,255,0.4);
}
.logo-emoji { font-size: 80rpx; }
.app-name { font-size: 60rpx; font-weight: 700; color: #fff; letter-spacing: 4rpx; }
.slogan { margin-top: 16rpx; font-size: 26rpx; color: rgba(255,255,255,0.85); }

/* ── 特性卡 ── */
.features { margin-top: 60rpx; display: flex; gap: 32rpx; }
.feature-item {
  display: flex; flex-direction: column; align-items: center;
  background: rgba(255,255,255,0.15); border-radius: 20rpx;
  padding: 24rpx 28rpx;
}
.feature-icon { font-size: 48rpx; }
.feature-label { margin-top: 10rpx; font-size: 22rpx; color: rgba(255,255,255,0.9); }

/* ── 底部按钮区 ── */
.bottom {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 0 48rpx 48rpx;
  display: flex; flex-direction: column; align-items: center;
}

/* 微信登录按钮 */
.login-btn.wx-btn {
  width: 100%; height: 96rpx; border-radius: 48rpx;
  background: #fff; color: #67C23A;
  font-size: 34rpx; font-weight: 700; border: none;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.2);
  display: flex; align-items: center; justify-content: center;
}
.login-btn.wx-btn::after { border: none; }
.login-btn.loading { opacity: 0.7; }

/* 分割线 */
.switch-row { display: flex; align-items: center; width: 100%; margin: 28rpx 0 20rpx; gap: 16rpx; }
.divider-line { flex: 1; height: 1rpx; background: rgba(255,255,255,0.35); }
.divider-text { font-size: 24rpx; color: rgba(255,255,255,0.7); white-space: nowrap; }

/* 账号表单卡片 */
.form-card {
  width: 100%; background: rgba(255,255,255,0.15);
  border-radius: 24rpx; padding: 24rpx 28rpx;
  backdrop-filter: blur(6px);
  margin-bottom: 12rpx;
}

/* Tab 切换 */
.form-tabs { display: flex; margin-bottom: 24rpx; background: rgba(255,255,255,0.2); border-radius: 12rpx; padding: 6rpx; }
.form-tab { flex: 1; text-align: center; padding: 16rpx 0; font-size: 28rpx; color: rgba(255,255,255,0.7); border-radius: 8rpx; transition: all 0.25s; }
.form-tab.active { background: #fff; color: #67C23A; font-weight: 600; }

/* 输入框 */
.input-item { margin-bottom: 16rpx; }
.input-field {
  width: 100%; height: 84rpx; line-height: 84rpx;
  padding: 0 28rpx; box-sizing: border-box;
  background: rgba(255,255,255,0.9); border-radius: 12rpx;
  font-size: 28rpx; color: #333; border: none;
}
.ph { color: #aaa; font-size: 28rpx; }

/* 提交按钮 */
.submit-btn {
  width: 100%; height: 88rpx; border-radius: 44rpx;
  background: #fff; color: #67C23A;
  font-size: 32rpx; font-weight: 700; border: none;
  margin-top: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
}
.submit-btn::after { border: none; }
.submit-btn.loading { opacity: 0.7; }

/* 切换展开按钮 */
.toggle-account {
  font-size: 26rpx; color: rgba(255,255,255,0.85);
  padding: 16rpx 0 8rpx; text-decoration: underline;
}

.tip { margin-top: 12rpx; font-size: 22rpx; color: rgba(255,255,255,0.6); }

