.page {
    height: 100vh;
    display: flex;
    flex-direction: column;
    background: #f7f8fa;
}

.list { flex: 1; padding: 20rpx; }

/* 加载 & 空状态 */
.loading-wrap {
    display: flex;
    justify-content: center;
    gap: 12rpx;
    padding: 120rpx 0;
}
.loading-dot {
    width: 14rpx; height: 14rpx; border-radius: 50%;
    background: #FF5722;
    animation: bounce 1.2s infinite ease-in-out;
}
.loading-dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce {
    0%,80%,100% { transform: scale(0.4); opacity: 0.4; }
    40% { transform: scale(1); opacity: 1; }
}
.empty-wrap {
    display: flex; flex-direction: column;
    align-items: center; padding: 160rpx 40rpx; gap: 16rpx;
}
.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 30rpx; font-weight: 500; color: #606266; }
.empty-hint { font-size: 24rpx; color: #C0C4CC; text-align: center; }

/* 举报卡片 */
.report-card {
    background: #fff;
    border-radius: 20rpx;
    padding: 28rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 18rpx;
}
.type-row { display: flex; gap: 12rpx; flex-wrap: wrap; }
.type-tag {
    font-size: 22rpx; background: #f0f0f0;
    color: #666; padding: 4rpx 14rpx; border-radius: 20rpx;
}
.reason-tag {
    font-size: 22rpx; background: #FFF3E0;
    color: #FF5722; padding: 4rpx 14rpx; border-radius: 20rpx;
}

/* 状态 Badge */
.status-badge {
    font-size: 22rpx; padding: 6rpx 18rpx;
    border-radius: 20rpx; white-space: nowrap; flex-shrink: 0;
}
.status-pending  { background: #E8F4FD; color: #409EFF; }
.status-handled  { background: #F0F9EB; color: #4CAF50; }
.status-rejected { background: #f4f4f5; color: #909399; }

/* 快照 */
.snapshot { margin-bottom: 14rpx; }
.snapshot-title {
    font-size: 28rpx; color: #333; font-weight: 500;
    display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden;
}

/* 描述 */
.desc {
    display: block; font-size: 26rpx; color: #606266;
    line-height: 1.6; margin-bottom: 16rpx;
}

/* 证据图片 */
.evidence-images { display: flex; gap: 12rpx; flex-wrap: wrap; margin-bottom: 16rpx; }
.evidence-img {
    width: 120rpx; height: 120rpx;
    border-radius: 12rpx; object-fit: cover;
}

/* 管理员回复 */
.result-box {
    background: #F0F9EB; border-left: 4rpx solid #4CAF50;
    border-radius: 0 12rpx 12rpx 0; padding: 16rpx 20rpx;
    margin-bottom: 16rpx;
}
.result-label { font-size: 22rpx; color: #4CAF50; display: block; margin-bottom: 8rpx; }
.result-note { font-size: 26rpx; color: #333; line-height: 1.6; }

/* 时间 */
.time { font-size: 22rpx; color: #C0C4CC; display: block; text-align: right; }
