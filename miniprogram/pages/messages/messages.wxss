.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: var(--color-bg-page);
}

.system-notify-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #fff;
  padding: 30rpx var(--space-md);
  margin-bottom: var(--space-sm);
}

.system-notify-card .left {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.system-notify-card .icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background-color: var(--color-primary-light);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.system-notify-card .title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text-primary);
}

.system-notify-card .arrow {
  color: var(--color-text-placeholder);
  font-size: var(--font-lg);
}

.session-divider {
  padding: var(--space-sm) var(--space-md);
  font-size: var(--font-md);
  color: var(--color-text-secondary);
}

.session-list {
  flex: 1;
  background-color: #fff;
  padding: 0 var(--space-md);
}

.session-card {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 2rpx solid var(--color-border-light);
  gap: var(--space-md);
}

.session-card:last-child {
  border-bottom: none;
}

.avatar-box {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-primary);
  font-size: 40rpx;
  font-weight: bold;
}

.avatar-box .avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-box .badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  background-color: #F56C6C;
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 4rpx;
  box-sizing: border-box;
}

.content-box {
  flex: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.top-row .name {
  font-size: var(--font-lg);
  font-weight: 500;
  color: var(--color-text-primary);
}

.top-row .time {
  font-size: var(--font-sm);
  color: var(--color-text-placeholder);
}

.bottom-row {
  display: flex;
  align-items: center;
  font-size: var(--font-md);
  color: var(--color-text-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.bottom-row .task-title {
  color: var(--color-primary);
  margin-right: 8rpx;
  flex-shrink: 0;
}

.bottom-row .last-msg {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: var(--color-text-placeholder);
  font-size: var(--font-md);
}
