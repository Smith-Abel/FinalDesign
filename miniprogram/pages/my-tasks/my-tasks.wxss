/* ── 状态 Tab ── */
.tab-bar {
    display: flex;
    background: #fff;
    padding: 0 8rpx;
    border-bottom: 1rpx solid #f0f0f0;
    position: sticky;
    top: 0;
    z-index: 10;
}
.tab-item {
    flex: 1;
    text-align: center;
    padding: 22rpx 4rpx;
    font-size: 26rpx;
    color: #909399;
    position: relative;
}
.tab-item.active {
    color: #4CAF50;
    font-weight: 600;
}
.tab-item.active::after {
    content: '';
    position: absolute;
    bottom: 0; left: 20%; right: 20%;
    height: 4rpx;
    background: #4CAF50;
    border-radius: 2rpx;
}

/* ── 加载 & 空状态 ── */
.loading-wrap, .empty-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 100rpx 40rpx;
    gap: 20rpx;
}
.loading-dot {
    width: 60rpx; height: 60rpx;
    border: 6rpx solid #e0e0e0;
    border-top-color: #4CAF50;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { color: #909399; font-size: 28rpx; }
.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 30rpx; color: #606266; font-weight: 500; }
.empty-hint { font-size: 24rpx; color: #C0C4CC; text-align: center; }

/* ── 任务列表 ── */
.task-list {
    height: calc(100vh - 100rpx);
    padding: 16rpx;
    box-sizing: border-box;
}

/* ── 任务卡片 ── */
.task-card {
    background: #fff;
    border-radius: 20rpx;
    padding: 28rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}
.card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 14rpx;
    gap: 16rpx;
}
.task-title {
    flex: 1;
    font-size: 30rpx;
    font-weight: 600;
    color: #303133;
    line-height: 1.4;
}
.task-content {
    font-size: 26rpx;
    color: #606266;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 18rpx;
}
.card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12rpx;
}
.meta-group {
    display: flex;
    flex-direction: column;
    gap: 6rpx;
}
.reward {
    font-size: 24rpx;
    color: #E6A23C;
    font-weight: 500;
}
.no-reward { color: #C0C4CC; }
.worker-info { font-size: 22rpx; color: #909399; }

/* ── 操作按钮 ── */
.action-group {
    display: flex;
    gap: 12rpx;
}
.btn-edit {
    background: #ECF5FF !important;
    color: #409EFF !important;
    border: 1rpx solid #b3d8ff !important;
    border-radius: 12rpx !important;
    font-size: 24rpx !important;
    padding: 0 24rpx !important;
    height: 56rpx !important;
    line-height: 56rpx !important;
}
.btn-cancel {
    background: #FEF0F0 !important;
    color: #F56C6C !important;
    border: 1rpx solid #fbc4c4 !important;
    border-radius: 12rpx !important;
    font-size: 24rpx !important;
    padding: 0 24rpx !important;
    height: 56rpx !important;
    line-height: 56rpx !important;
}

/* ── 状态 Badge ── */
.badge {
    font-size: 20rpx;
    padding: 4rpx 16rpx;
    border-radius: 20rpx;
    white-space: nowrap;
    flex-shrink: 0;
}
.badge-open     { background: #ecf5ff; color: #409EFF; }
.badge-progress { background: #fdf6ec; color: #E6A23C; }
.badge-pending  { background: #f0f9eb; color: #85ce61; }
.badge-done     { background: #f0f9eb; color: #4CAF50; }
.badge-cancel   { background: #f4f4f5; color: #909399; }

/* ── 编辑弹窗 ── */
.modal-mask {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 100;
    display: flex;
    align-items: flex-end;
}
.modal-box {
    width: 100%;
    background: #fff;
    border-radius: 32rpx 32rpx 0 0;
    padding: 40rpx 32rpx 60rpx;
    box-sizing: border-box;
    animation: slideUp 0.25s ease;
}
@keyframes slideUp {
    from { transform: translateY(100%); }
    to   { transform: translateY(0); }
}
.modal-title {
    font-size: 34rpx;
    font-weight: 700;
    color: #303133;
    text-align: center;
    margin-bottom: 36rpx;
}
.form-item {
    margin-bottom: 28rpx;
}
.form-label {
    display: block;
    font-size: 26rpx;
    color: #606266;
    margin-bottom: 10rpx;
}
.form-input {
    width: 100%;
    border: 1rpx solid #DCDFE6;
    border-radius: 14rpx;
    padding: 18rpx 20rpx;
    font-size: 28rpx;
    color: #303133;
    box-sizing: border-box;
    background: #fafafa;
}
.form-textarea {
    width: 100%;
    border: 1rpx solid #DCDFE6;
    border-radius: 14rpx;
    padding: 18rpx 20rpx;
    font-size: 28rpx;
    color: #303133;
    box-sizing: border-box;
    background: #fafafa;
    height: 180rpx;
    line-height: 1.6;
}
.modal-actions {
    display: flex;
    gap: 20rpx;
    margin-top: 20rpx;
}
.btn-modal-cancel {
    flex: 1;
    background: #f4f4f5 !important;
    color: #606266 !important;
    border: none !important;
    border-radius: 16rpx !important;
    height: 88rpx !important;
    line-height: 88rpx !important;
    font-size: 30rpx !important;
}
.btn-modal-save {
    flex: 2;
    background: linear-gradient(135deg, #4CAF50, #2E7D32) !important;
    color: #fff !important;
    border: none !important;
    border-radius: 16rpx !important;
    height: 88rpx !important;
    line-height: 88rpx !important;
    font-size: 30rpx !important;
    font-weight: 600 !important;
}
.btn-modal-save.disabled {
    opacity: 0.6;
}
