<view class="container">
  <!-- 头部全阅读按钮 -->
  <view class="header" wx:if="{{notifications.length > 0}}">
    <text class="count-text">共 {{notifications.length}} 条通知</text>
    <view class="read-all-btn" bindtap="handleReadAll">全部已读</view>
  </view>

  <!-- 消息列表 -->
  <scroll-view class="notification-list" scroll-y enable-flex>
    <view 
      wx:for="{{notifications}}" 
      wx:key="id" 
      class="notice-card {{item.is_read ? 'is-read' : 'unread'}}"
      data-id="{{item.id}}"
      data-task-id="{{item.related_task_id}}"
      bindtap="handleClickNotice"
    >
      <view class="top-row">
        <view class="notice-type">
          <text class="dot" wx:if="{{!item.is_read}}"></text>
          {{item.notify_type_label}}
        </view>
        <text class="time">{{item.created_at}}</text>
      </view>
      <view class="content">
        {{item.content}}
      </view>
      <view class="arrow" wx:if="{{item.related_task_id}}">查看详情 ></view>
    </view>
  </scroll-view>

  <view wx:if="{{isLoading}}" class="loading">加载中...</view>
  <view wx:elif="{{notifications.length === 0}}" class="empty">
    暂无新消息
  </view>
</view>
