page {
  background-color: #f7f8fa;
  box-sizing: border-box;
}

.container {
  padding: 20rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 20rpx 30rpx;
}

.count-text {
  font-size: 26rpx;
  color: #909399;
}

.read-all-btn {
  font-size: 26rpx;
  color: #409EFF;
  padding: 10rpx;
}

.notification-list {
  display: flex;
  flex-direction: column;
}

.notice-card {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  position: relative;
  transition: all 0.3s ease;
}

.notice-card.is-read {
  opacity: 0.6;
}

.top-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.notice-type {
  font-size: 28rpx;
  font-weight: bold;
  color: #303133;
  display: flex;
  align-items: center;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #F56C6C;
  border-radius: 50%;
  margin-right: 12rpx;
}

.time {
  font-size: 24rpx;
  color: #C0C4CC;
}

.content {
  font-size: 28rpx;
  color: #606266;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.arrow {
  text-align: right;
  font-size: 24rpx;
  color: #409EFF;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #909399;
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 20rpx 0;
  color: #909399;
  font-size: 26rpx;
}
