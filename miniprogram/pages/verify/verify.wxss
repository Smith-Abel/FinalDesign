page {
  background-color: #f7f8fa;
}

.page {
  padding: 30rpx;
}

.header {
  margin-bottom: 50rpx;
}

.title {
  font-size: 38rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.subtitle {
  font-size: 26rpx;
  color: #888;
  margin-top: 10rpx;
  display: block;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 100rpx;
  color: #999;
}

.status-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.status-card .icon-wrap {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.status-card.approved .status-title {
  color: #67C23A;
  font-size: 36rpx;
  font-weight: bold;
}

.status-card.pending .status-title {
  color: #E6A23C;
  font-size: 36rpx;
  font-weight: bold;
}

.status-desc {
  font-size: 28rpx;
  color: #666;
  margin-top: 20rpx;
  line-height: 1.5;
}

.reject-alert {
  background: #fef0f0;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  border-left: 8rpx solid #F56C6C;
}

.alert-title {
  font-weight: bold;
  color: #F56C6C;
  font-size: 28rpx;
  display: block;
}

.alert-desc, .alert-tip {
  font-size: 26rpx;
  color: #F56C6C;
  display: block;
  margin-top: 6rpx;
}

.form-container {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.form-section {
  margin-bottom: 40rpx;
}

.label {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.required {
  color: #F56C6C;
}

.input {
  width: 100%;
  height: 88rpx;
  background: #f7f8fa;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.upload-area {
  width: 100%;
  height: 320rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
  border: 1px dashed #dcdfe6;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #909399;
}

.upload-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.upload-text {
  font-size: 26rpx;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #409EFF;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  margin-top: 60rpx;
}

.submit-btn[disabled] {
  opacity: 0.6;
}

.safe-note {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 30rpx;
}
