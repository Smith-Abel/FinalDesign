<view class="page" wx:if="{{user}}">

  <!-- ① 顶部用户信息卡片 -->
  <view class="hero-card">
    <!-- 头像（可点击修改） -->
    <view class="avatar-area" bindtap="changeAvatar">
      <image wx:if="{{user.avatar}}" src="{{user.avatar}}" class="avatar" mode="aspectFill"/>
      <view wx:else class="avatar-placeholder">
        <text>{{user.username[0]}}</text>
      </view>
      <view class="avatar-edit-badge">📷</view>
    </view>

    <!-- 右侧信息 -->
    <view class="user-meta" bindtap="editProfile">
      <text class="username">{{user.nickname || user.username}} <text style="font-size: 28rpx; color: #909399; margin-left: 8rpx;">✏️</text></text>
      <view class="tag-row">
        <view class="tag" wx:if="{{user.college}}">{{user.college}}</view>
        <view class="tag tag-verified" wx:if="{{user.student_id}}">已认证</view>
      </view>
      <view class="stat-row">
        <view class="stat-item" bindtap="goToCredits">
          <text class="stat-num">{{user.credit_score}}</text>
          <text class="stat-label">积分 ›</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num">{{user.tasks_created || 0}}</text>
          <text class="stat-label">发布</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num">{{user.tasks_done || 0}}</text>
          <text class="stat-label">完成</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ② 资料完善提示 -->
  <view class="tip-card" wx:if="{{!user.profile_reward_given}}">
    <text class="tip-icon">🎁</text>
    <text class="tip-text">完善学号、头像、学院可获得 <text class="tip-credit">+15积分</text></text>
    <view class="tip-btn" bindtap="editProfile">去完善</view>
  </view>

  <!-- ③ 任务快捷入口（仿携程"我的订单"区域） -->
  <view class="section card">
    <view class="section-header">
      <text class="section-title">我的任务</text>
      <view class="section-more" bindtap="goToMyTasks">全部 ›</view>
    </view>
    <view class="quick-grid">
      <view class="quick-item" bindtap="goToTab" data-tab="published">
        <text class="quick-icon">📋</text>
        <text class="quick-label">发布的任务</text>
      </view>
      <view class="quick-item" bindtap="goToTab" data-tab="in_progress">
        <text class="quick-icon">🔄</text>
        <text class="quick-label">进行中的任务</text>
      </view>
      <view class="quick-item" bindtap="goToTab" data-tab="completed">
        <text class="quick-icon">✅</text>
        <text class="quick-label">完成的任务</text>
      </view>
    </view>
  </view>

  <!-- ④ 工具菜单 -->
  <view class="section card">
    <view class="section-title">我的工具</view>
    <view class="menu-item" bindtap="goToCredits">
      <view class="menu-icon-wrap"><text class="menu-icon">🪙</text></view>
      <text class="menu-label">积分明细</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToMyReports">
      <view class="menu-icon-wrap"><text class="menu-icon">🚩</text></view>
      <text class="menu-label">我的举报</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToSettings">
      <view class="menu-icon-wrap"><text class="menu-icon">⚙️</text></view>
      <text class="menu-label">设置</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item danger" bindtap="handleLogout">
      <view class="menu-icon-wrap"><text class="menu-icon">🚪</text></view>
      <text class="menu-label">退出登录</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

</view>

<!-- ⑤ 内联编辑弹窗 -->
<view class="modal-mask" wx:if="{{showEditModal}}" bindtap="closeEdit">
    <view class="modal-box" catchtap="noop">
      <view class="modal-title">编辑资料</view>
      <view class="form-item">
        <text class="field-label">昵称</text>
        <input class="field-input" placeholder="请输入昵称" value="{{editForm.nickname}}"
          bindinput="onInput" data-field="nickname" />
      </view>
      <view class="form-item">
        <text class="field-label">用户名</text>
        <input class="field-input" value="{{user.username}}" disabled="true" placeholder="注册时分配，无法修改" style="color: #999;"/>
      </view>
      <view class="form-item">
      <text class="field-label">性别</text>
      <picker mode="selector" range="{{genderOptions}}" range-key="label"
        value="{{genderIdx}}" bindchange="onGenderChange" style="flex: 1;">
        <view class="picker-val">{{genderLabel}} ›</view>
      </picker>
    </view>
    <view class="form-item">
      <text class="field-label">学号</text>
      <input class="field-input" placeholder="请输入学号" value="{{editForm.student_id}}"
        bindinput="onInput" data-field="student_id" />
    </view>
    <view class="form-item">
      <text class="field-label">学院</text>
      <input class="field-input" placeholder="请输入所在学院" value="{{editForm.college}}"
        bindinput="onInput" data-field="college" />
    </view>
    <view class="modal-actions">
      <button class="btn-modal-cancel" bindtap="closeEdit">取消</button>
      <button class="btn-modal-save {{isSaving ? 'disabled' : ''}}"
        loading="{{isSaving}}" disabled="{{isSaving}}" bindtap="handleSave">
        {{isSaving ? '保存中…' : '保存'}}
      </button>
    </view>
  </view>
</view>

<!-- 骨架屏 -->
<view class="skeleton-wrap" wx:elif="{{!user}}">
  <view class="skeleton-block hero"></view>
</view>
